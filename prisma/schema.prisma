generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  employeeId       String             @unique
  fullName         String
  email            String             @unique
  mobile           String
  department       String
  jobTitle         String
  preferredLanguage String           @default("ar")
  passwordHash     String
  roles            Role[]             @default([USER])
  canManageTrainerNeeds Boolean       @default(false)
  status           Status             @default(PENDING)
  avatar           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  requests         Request[]
  custodyRecords   CustodyRecord[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  undertaking      Undertaking?
  sentMessages     InternalMessage[]  @relation("SentMessages")
  receivedMessages InternalMessage[]  @relation("ReceivedMessages")
  returnRequests   ReturnRequest[]    @relation("RequestedReturns")
  assignedTrainerNeeds TrainerNeed[]   @relation("AssignedTrainerNeeds")
  trainerNeedReservations StoreReservation[]
  approvedRoomBookings TrainingRoomBooking[] @relation("ApprovedRoomBookings")

  @@map("users")
}

model Undertaking {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accepted   Boolean  @default(false)
  acceptedAt DateTime?
  version    String   @default("1.0")
  ipAddress  String?

  @@map("undertakings")
}

enum Role {
  MANAGER
  WAREHOUSE
  USER
}

enum Status {
  ACTIVE
  PENDING
  DISABLED
  REJECTED
}

model InventoryItem {
  id                     String               @id @default(cuid())
  code                   String               @unique
  name                   String
  description            String?
  category               String
  subcategory            String?
  type                   ItemType
  quantity               Int                  @default(0)
  availableQty           Int                  @default(0)
  reservedQty            Int                  @default(0)
  minStock               Int                  @default(5)
  unit                   String               @default("قطعة")
  maintenanceIntervalDays Int?
  nextMaintenanceDueAt   DateTime?
  location               String?
  status                 ItemStatus           @default(AVAILABLE)
  unitPrice              Decimal?             @db.Decimal(12, 2)
  totalPrice             Decimal?             @db.Decimal(14, 2)
  financialTracking      Boolean              @default(false)
  notes                  String?
  imageUrl               String?
  sortOrder              Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  requestItems           RequestItem[]
  custodyRecords         CustodyRecord[]
  maintenanceRequests    MaintenanceRequest[]
  storeCatalogItems      StoreCatalogItem[]
  trainerNeedItems       TrainerNeedItem[]
  storeReservations      StoreReservation[]

  @@index([code])
  @@index([name])
  @@index([category])
  @@index([subcategory])
  @@index([status])
  @@index([nextMaintenanceDueAt])
  @@map("inventory_items")
}

enum ItemType {
  RETURNABLE
  CONSUMABLE
}

enum ItemStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
}

model Request {
  id              String        @id @default(cuid())
  code            String        @unique
  requesterId     String
  requester       User          @relation(fields: [requesterId], references: [id])
  department      String
  purpose         String
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  notes           String?
  createdAt       DateTime      @default(now())
  processedAt     DateTime?
  processedById   String?
  items           RequestItem[]
  custodyRecords  CustodyRecord[]
  trainerNeeds    TrainerNeed[]

  @@index([status])
  @@map("requests")
}

model RequestItem {
  id             String          @id @default(cuid())
  requestId      String
  request        Request         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  itemId         String
  item           InventoryItem   @relation(fields: [itemId], references: [id])
  quantity       Int
  notes          String?
  returnRequests ReturnRequest[]

  @@map("request_items")
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ISSUED
  RETURNED
}

model CustodyRecord {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  itemId          String
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  requestId       String?
  request         Request?       @relation(fields: [requestId], references: [id])
  quantity        Int
  issueDate       DateTime       @default(now())
  expectedReturn  DateTime?
  actualReturn    DateTime?
  returnCondition String?
  status          CustodyStatus  @default(ACTIVE)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  returnRequests  ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@map("custody_records")
}

enum CustodyStatus {
  ACTIVE
  RETURN_REQUESTED
  RETURNED
  OVERDUE
}

model ReturnRequest {
  id              String              @id @default(cuid())
  code            String              @unique

  custodyId       String?
  custody         CustodyRecord?      @relation(fields: [custodyId], references: [id])

  requestItemId   String?
  requestItem     RequestItem?        @relation(fields: [requestItemId], references: [id])

  requesterId     String
  requester       User                @relation("RequestedReturns", fields: [requesterId], references: [id])

  sourceType      ReturnSourceType    @default(CUSTODY)
  quantity        Int                 @default(1)

  conditionNote   String?
  status          ReturnStatus        @default(PENDING)
  processedById   String?
  processedAt     DateTime?
  rejectionReason String?
  returnType      ReturnItemCondition @default(GOOD)
  damageDetails   String?
  damageImages    String?
  declarationAck  Boolean             @default(false)
  receivedType    ReturnItemCondition?
  receivedNotes   String?
  receivedImages  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([custodyId])
  @@index([requestItemId])
  @@index([requesterId])
  @@index([status])
  @@map("return_requests")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnItemCondition {
  GOOD
  PARTIAL_DAMAGE
  TOTAL_DAMAGE
}

enum ReturnSourceType {
  CUSTODY
  REQUEST_ITEM
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  code        String            @unique
  requesterId String
  itemId      String?
  item        InventoryItem?    @relation(fields: [itemId], references: [id])
  category    String
  description String
  priority    Priority          @default(NORMAL)
  status      MaintenanceStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("maintenance_requests")
}

model PurchaseRequest {
  id               String         @id @default(cuid())
  code             String         @unique
  requesterId      String
  items            String
  reason           String
  budgetNote       String?
  estimatedValue   Float?
  status           PurchaseStatus @default(PENDING)
  targetDepartment String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("purchase_requests")
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum PurchaseStatus {
  PENDING
  APPROVED
  ORDERED
  RECEIVED
  REJECTED
}

model Suggestion {
  id            String           @id @default(cuid())
  title         String
  description   String
  justification String
  category      String
  priority      Priority         @default(NORMAL)
  requesterId   String
  status        SuggestionStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("suggestions")
}

enum SuggestionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  link       String?
  entityId   String?
  entityType String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model EmailDraft {
  id         String      @id @default(cuid())
  sourceType String
  sourceId   String
  recipient  String
  subject    String
  body       String
  status     DraftStatus @default(DRAFT)
  copiedAt   DateTime?
  createdAt  DateTime    @default(now())

  @@map("email_drafts")
}

enum DraftStatus {
  DRAFT
  COPIED
  SENT
}

model InternalMessage {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  subject     String
  body        String
  relatedType String?
  relatedId   String?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([receiverId, isRead])
  @@map("internal_messages")
}

model StoreCatalogItem {
  id              String              @id @default(cuid())
  inventoryItemId String?
  inventoryItem   InventoryItem?      @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  category        String
  imageUrl        String?
  isVisible       Boolean             @default(true)
  isOnDemand      Boolean             @default(false)
  onDemandNote    String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  trainerNeedItems TrainerNeedItem[]
  bundleItems      StoreBundleItem[]
  alternativesFrom StoreItemAlternative[] @relation("AlternativeSource")
  alternativesTo   StoreItemAlternative[] @relation("AlternativeTarget")

  @@index([inventoryItemId])
  @@index([category])
  @@index([isVisible])
  @@map("store_catalog_items")
}

model StoreItemAlternative {
  id            String           @id @default(cuid())
  sourceItemId  String
  sourceItem    StoreCatalogItem @relation("AlternativeSource", fields: [sourceItemId], references: [id], onDelete: Cascade)
  alternativeId String
  alternative   StoreCatalogItem @relation("AlternativeTarget", fields: [alternativeId], references: [id], onDelete: Cascade)
  note          String?
  requiresTrainerApproval Boolean @default(false)
  createdAt     DateTime         @default(now())

  @@unique([sourceItemId, alternativeId])
  @@index([alternativeId])
  @@map("store_item_alternatives")
}

model StoreBundle {
  id          String            @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  isVisible   Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       StoreBundleItem[]

  @@index([isVisible])
  @@map("store_bundles")
}

model StoreBundleItem {
  id            String           @id @default(cuid())
  bundleId      String
  bundle        StoreBundle      @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  catalogItemId String
  catalogItem   StoreCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  quantity      Int              @default(1)
  quantityMode  StoreBundleQuantityMode @default(FIXED)

  @@unique([bundleId, catalogItemId])
  @@index([catalogItemId])
  @@map("store_bundle_items")
}

enum StoreBundleQuantityMode {
  FIXED
  PER_TRAINEE
}

model TrainerNeed {
  id             String            @id @default(cuid())
  code           String            @unique
  trainerName    String
  courseName     String
  traineeCount   Int
  startDate      DateTime
  endDate        DateTime?
  status         TrainerNeedStatus @default(NEW)
  readinessScore Int               @default(0)
  assignedToId   String?
  assignedTo     User?             @relation("AssignedTrainerNeeds", fields: [assignedToId], references: [id], onDelete: SetNull)
  decisionNote   String?
  linkedRequestId String?
  linkedRequest   Request?         @relation(fields: [linkedRequestId], references: [id], onDelete: SetNull)
  roomBooking    TrainingRoomBooking?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          TrainerNeedItem[]

  @@index([status])
  @@index([assignedToId])
  @@index([startDate])
  @@map("trainer_needs")
}

model TrainerNeedItem {
  id                    String                 @id @default(cuid())
  needId                String
  need                  TrainerNeed            @relation(fields: [needId], references: [id], onDelete: Cascade)
  catalogItemId          String?
  catalogItem            StoreCatalogItem?      @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  inventoryItemId        String?
  inventoryItem          InventoryItem?         @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  title                  String
  requestedQty           Int
  availableAtSubmission  Int                    @default(0)
  reservedQty            Int                    @default(0)
  shortageQty            Int                    @default(0)
  approvedQty            Int                    @default(0)
  status                 TrainerNeedItemStatus  @default(REQUESTED)
  handlingMode           TrainerNeedHandlingMode?
  coordinatorNote        String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  reservations           StoreReservation[]

  @@index([needId])
  @@index([catalogItemId])
  @@index([inventoryItemId])
  @@index([status])
  @@map("trainer_need_items")
}

model StoreReservation {
  id             String                 @id @default(cuid())
  needItemId     String
  needItem       TrainerNeedItem        @relation(fields: [needItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Int
  status          StoreReservationStatus @default(ACTIVE)
  createdById     String?
  createdBy       User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())
  releasedAt      DateTime?

  @@index([inventoryItemId, status])
  @@index([needItemId])
  @@map("store_reservations")
}

model TrainingRoom {
  id              String                @id @default(cuid())
  name            String
  type            String
  capacity        Int                   // السعة الأساسية
  maxCapacity     Int?                  // السعة القصوى (يساوي capacity إذا لم يُحدَّد)
  location        String?
  description     String?
  equipment       String[]              @default([])
  layoutOptions   String[]              @default([])
  imageUrl        String?
  isVisible       Boolean               @default(true)
  sortOrder       Int                   @default(0)
  internalNotes   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  requestedBookings TrainingRoomBooking[] @relation("RequestedRoom")
  approvedBookings  TrainingRoomBooking[] @relation("ApprovedRoom")

  @@index([isVisible])
  @@index([type])
  @@index([capacity])
  @@map("training_rooms")
}

model TrainingRoomBooking {
  id              String                    @id @default(cuid())
  trainerNeedId   String                    @unique
  trainerNeed     TrainerNeed               @relation(fields: [trainerNeedId], references: [id], onDelete: Cascade)
  requestedRoomId String?
  requestedRoom   TrainingRoom?             @relation("RequestedRoom", fields: [requestedRoomId], references: [id], onDelete: SetNull)
  approvedRoomId  String?
  approvedRoom    TrainingRoom?             @relation("ApprovedRoom", fields: [approvedRoomId], references: [id], onDelete: SetNull)
  status          TrainingRoomBookingStatus @default(REQUESTED)
  requestedLayout String?
  requestedPlan   Json?
  coordinatorNote String?
  startDate       DateTime
  endDate         DateTime
  approvedById    String?
  approvedBy      User?                     @relation("ApprovedRoomBookings", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([requestedRoomId])
  @@index([approvedRoomId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("training_room_bookings")
}

enum TrainingRoomBookingStatus {
  REQUESTED
  APPROVED
  ALTERNATIVE_PROPOSED
  CANCELLED
}

enum TrainerNeedStatus {
  NEW
  IN_REVIEW
  ASSIGNED
  PLAN_PROPOSED
  RESERVED_AVAILABLE
  SHORTAGE_IN_PROGRESS
  READY_TO_REQUEST
  CONVERTED_TO_REQUEST
  COMPLETED
  CANCELLED
}

enum TrainerNeedItemStatus {
  REQUESTED
  AVAILABLE
  RESERVED
  SHORTAGE
  ALTERNATIVE_PROPOSED
  ON_DEMAND
  CANCELLED
  CONVERTED
}

enum TrainerNeedHandlingMode {
  RESERVE_FROM_STOCK
  USE_ALTERNATIVE
  WAIT_FOR_STOCK
  INTERNAL_SOURCE
  TRY_TO_PROVIDE
  CANCEL_ITEM
}

enum StoreReservationStatus {
  ACTIVE
  RELEASED
  CONVERTED
  CANCELLED
}
